# Required
GEMINI_API_KEY=
VOYAGE_API_KEY=
JWT_SECRET=change-me-to-a-random-secret

# Optional (works unauthenticated at lower rate limits)
SEMANTIC_SCHOLAR_API_KEY=

# Set automatically by docker-compose (uses the "db" service hostname internally).
# If running the backend outside Docker against the dockerized Postgres, use localhost:5433
# (5433 avoids clashing with any Postgres already running locally on 5432).
DATABASE_URL=postgresql+psycopg://research_assistant:research_assistant@localhost:5433/research_assistant
